{
  "name": "@davanhs/rate-limiter-hono",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2022 --sourcemap",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@davanhs/rate-limiter": "workspace:*",
    "hono": "^4.12.18",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.23"
  }
}
