{
  "name": "@davanhs/rate-limiter-express",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --target es2022 --sourcemap",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@davanhs/rate-limiter": "workspace:*",
    "express": "^4.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2"
  }
}
